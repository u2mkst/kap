
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile in the Class Hub academy.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "nickname": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "schoolName": { "type": "string" },
        "grade": { "type": "string" },
        "classNum": { "type": "string" },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "nickname", "points"]
    },
    "Plant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Plant",
      "type": "object",
      "description": "A virtual plant belonging to a user.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "plantName": { "type": "string" },
        "plantType": { "type": "string" },
        "growthStage": { "type": "string", "enum": ["Seed", "Sprout", "Sapling", "Mature"] },
        "pointsInvested": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "plantName", "growthStage", "pointsInvested"]
    },
    "Post": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorNickname": { "type": "string" },
        "content": { "type": "string" },
        "grade": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "authorNickname", "content", "grade"]
    },
    "Comment": {
      "title": "Comment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorNickname": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/users/{userId}/plants/{plantId}",
        "definition": {
          "entityName": "Plant",
          "schema": { "$ref": "#/backend/entities/Plant" },
          "description": "Virtual plants grown by users."
        }
      },
      {
        "path": "/posts/{postId}",
        "definition": {
          "entityName": "Post",
          "schema": { "$ref": "#/backend/entities/Post" },
          "description": "Lounge community posts."
        }
      },
      {
        "path": "/posts/{postId}/comments/{commentId}",
        "definition": {
          "entityName": "Comment",
          "schema": { "$ref": "#/backend/entities/Comment" },
          "description": "Comments on lounge posts."
        }
      }
    ]
  }
}
