
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile in the Class Hub academy, including personal details, points, and school information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (UID) for the User."
        },
        "username": {
          "type": "string",
          "description": "Academy unique ID (ufes--- format)."
        },
        "firstName": {
          "type": "string",
          "description": "First name."
        },
        "lastName": {
          "type": "string",
          "description": "Last name."
        },
        "schoolName": {
          "type": "string",
          "description": "Name of the school the student attends."
        },
        "grade": {
          "type": "string",
          "description": "Current grade level."
        },
        "classNum": {
          "type": "string",
          "description": "Current class number."
        },
        "points": {
          "type": "number",
          "description": "Accumulated gamification points."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "username",
        "firstName",
        "lastName",
        "points"
      ]
    },
    "UserPlant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserPlant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "plantName": { "type": "string" },
        "plantType": { "type": "string" },
        "growthStage": { "type": "string" },
        "pointsInvested": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "plantType", "growthStage", "pointsInvested"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Individual user profiles."
        }
      },
      {
        "path": "/users/{userId}/plants/{userPlantId}",
        "definition": {
          "entityName": "UserPlant",
          "schema": { "$ref": "#/backend/entities/UserPlant" },
          "description": "Virtual plants owned by a user."
        }
      }
    ]
  }
}
