
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile in the Class Hub academy.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "nickname": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "schoolName": { "type": "string" },
        "grade": { "type": "string" },
        "classNum": { "type": "string" },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "nickname", "points"]
    },
    "Teacher": {
      "title": "Teacher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "vote": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "vote"]
    },
    "DailyProblem": {
      "title": "DailyProblem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "grade": { "type": "string" },
        "title": { "type": "string" },
        "topic": { "type": "string" },
        "difficulty": { "type": "string" },
        "problemText": { "type": "string" },
        "answer": { "type": "string" },
        "rewardPoints": { "type": "number" }
      },
      "required": ["date", "grade", "title", "problemText", "answer"]
    },
    "AppMetadata": {
      "title": "AppMetadata",
      "type": "object",
      "properties": {
        "notice": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles."
    },
    "/teachers/{teacherId}": {
      "schema": { "$ref": "#/backend/entities/Teacher" },
      "description": "Teachers for popularity vote."
    },
    "/metadata/config": {
      "schema": { "$ref": "#/backend/entities/AppMetadata" },
      "description": "Global app configurations like notices."
    },
    "/daily_problems/{problemId}": {
      "schema": { "$ref": "#/backend/entities/DailyProblem" },
      "description": "Daily academic problems categorized by grade."
    }
  }
}
