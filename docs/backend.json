
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile in the KST HUB academy.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "nickname": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "schoolType": { "type": "string", "enum": ["초등학교", "중학교", "고등학교"] },
        "schoolName": { "type": "string" },
        "officeCode": { "type": "string" },
        "schoolCode": { "type": "string" },
        "grade": { "type": "string" },
        "classNum": { "type": "string" },
        "teacherId": { "type": "string" },
        "points": { "type": "number" },
        "theme": { "type": "string", "enum": ["light", "dark"], "default": "light" },
        "lastAttendanceDate": { "type": "string" },
        "attendanceStreak": { "type": "number", "default": 0 },
        "hasCompletedTutorial": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "nickname", "points", "schoolType"]
    },
    "SwordGameProfile": {
      "title": "SwordGameProfile",
      "type": "object",
      "description": "User's progress in the Sword Enhancement Game.",
      "properties": {
        "userId": { "type": "string" },
        "nickname": { "type": "string" },
        "level": { "type": "number", "default": 0 },
        "maxLevel": { "type": "number", "default": 0 },
        "totalAttempts": { "type": "number", "default": 0 },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "nickname", "level"]
    },
    "AttendanceLog": {
      "title": "AttendanceLog",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["date"]
    },
    "UserFortune": {
      "title": "UserFortune",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "score": { "type": "number" },
        "comment": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["score", "date"]
    },
    "Plant": {
      "title": "Plant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "plantName": { "type": "string" },
        "plantType": { "type": "string" },
        "growthStage": { "type": "string", "enum": ["Seed", "Sprout", "Sapling", "Mature"] },
        "pointsInvested": { "type": "number" },
        "targetSprout": { "type": "number" },
        "targetSapling": { "type": "number" },
        "targetMature": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Teacher": {
      "title": "Teacher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "vote": { "type": "number" }
      }
    },
    "Inquiry": {
      "title": "Inquiry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "replied"] }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles."
    },
    "/users/{userId}/games/sword": {
      "schema": { "$ref": "#/backend/entities/SwordGameProfile" },
      "description": "User's sword enhancement state."
    },
    "/game_leaderboards/sword": {
      "schema": { "type": "object" },
      "description": "Collection to query all sword game profiles for ranking."
    }
  }
}
