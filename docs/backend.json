
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile in the KST HUB academy.",
      "properties": {
        "id": { "type": "string" },
        "phoneNumber": { "type": "string", "description": "User's verified phone number." },
        "username": { "type": "string", "description": "Legacy ufes ID (optional)." },
        "nickname": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "schoolType": { "type": "string", "enum": ["초등학교", "중학교", "고등학교"] },
        "schoolName": { "type": "string" },
        "officeCode": { "type": "string" },
        "schoolCode": { "type": "string" },
        "grade": { "type": "string" },
        "classNum": { "type": "string" },
        "teacherId": { "type": "string" },
        "points": { "type": "number" },
        "theme": { "type": "string", "enum": ["light", "dark"], "default": "light" },
        "isOnline": { "type": "boolean", "default": false },
        "lastSeen": { "type": "string", "format": "date-time" },
        "lastAttendanceDate": { "type": "string" },
        "attendanceStreak": { "type": "number", "default": 0 },
        "hasCompletedTutorial": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "phoneNumber", "nickname", "points", "schoolType"]
    },
    "Friend": {
      "title": "Friend",
      "type": "object",
      "description": "A simplified reference to a friend.",
      "properties": {
        "friendId": { "type": "string" },
        "nickname": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      }
    },
    "SwordGameProfile": {
      "title": "SwordGameProfile",
      "type": "object",
      "description": "User's progress in the Sword Enhancement Game.",
      "properties": {
        "userId": { "type": "string" },
        "nickname": { "type": "string" },
        "level": { "type": "number", "default": 0 },
        "maxLevel": { "type": "number", "default": 0 },
        "totalAttempts": { "type": "number", "default": 0 },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "nickname", "level"]
    }
  },
  "auth": {
    "providers": ["phone", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles."
    },
    "/users/{userId}/friends/{friendId}": {
      "schema": { "$ref": "#/backend/entities/Friend" },
      "description": "User's friend list."
    },
    "/users/{userId}/games/sword": {
      "schema": { "$ref": "#/backend/entities/SwordGameProfile" },
      "description": "User's sword enhancement state."
    },
    "/sword_game_profiles/{profileId}": {
      "schema": { "$ref": "#/backend/entities/SwordGameProfile" },
      "description": "Global sword game profiles for ranking."
    }
  }
}
