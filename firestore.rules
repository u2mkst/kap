
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 공통 함수 정의
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUserAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // 유저 정보 및 하위 컬렉션
    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      
      match /personal_fortunes/{date} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      }

      match /attendance_logs/{date} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      }

      match /plants/{plantId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      }

      match /solved_problems/{date} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      }
    }

    // 선생님 정보
    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }

    // 앱 설정 및 공지
    match /metadata/{docId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }

    // 관리자 권한 확인 및 획득
    match /roles_admin/{adminId} {
      // 본인의 관리자 여부 확인 허용
      allow get: if isAuthenticated() && request.auth.uid == adminId;
      // 관리자는 전체 관리자 목록 조회 가능
      allow list: if isUserAdmin();
      // 인증 코드를 통한 관리자 권한 직접 생성 허용 (최초 획득 시 필요)
      allow create: if isAuthenticated() && request.auth.uid == adminId;
      // 기존 관리자 정보 수정 및 삭제는 관리자만 가능
      allow update, delete: if isUserAdmin();
    }
    
    // 일일 문제
    match /daily_problems/{problemId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    // 오늘의 명언 (공개 데이터)
    match /daily_fortunes/{date} {
      allow read: if true;
      allow write: if isUserAdmin();
    }

    // 문의 시스템
    match /inquiries/{inquiryId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // 관리자는 전체 목록을 볼 수 있고, 학생은 자신의 것만 볼 수 있음
      allow list: if isUserAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow get: if isUserAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isUserAdmin();
    }

    // 명언 추천 시스템
    match /quote_suggestions/{suggestionId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // 관리자는 전체 목록을 볼 수 있고, 학생은 자신의 것만 볼 수 있음
      allow list: if isUserAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow get: if isUserAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isUserAdmin();
    }
  }
}
