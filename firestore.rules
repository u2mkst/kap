rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 공통 함수 정의
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUserAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // 1. 명언 추천 시스템 (사용자 요청에 따라 최우선 적용 및 단순화)
    // 로그인한 모든 사용자는 제약 없이 추천 목록을 보고 작성할 수 있음
    match /quote_suggestions/{suggestionId} {
      allow read, write: if isAuthenticated();
    }

    // 2. 관리자 권한 확인 및 획득
    match /roles_admin/{adminId} {
      allow get, create: if isAuthenticated() && request.auth.uid == adminId;
      allow list, update, delete: if isUserAdmin();
    }

    // 3. 유저 정보 및 하위 컬렉션
    match /users/{userId} {
      allow get, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      allow list: if isAuthenticated();
      
      match /personal_fortunes/{date} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      }

      match /attendance_logs/{date} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      }

      match /plants/{plantId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      }

      match /solved_problems/{date} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      }
    }

    // 4. 선생님 정보
    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }

    // 5. 앱 설정 및 공지
    match /metadata/{docId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
    
    // 6. 일일 문제
    match /daily_problems/{problemId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    // 7. 오늘의 명언 (공개 데이터)
    match /daily_fortunes/{date} {
      allow read: if true;
      allow write: if isUserAdmin();
    }

    // 8. 문의 시스템
    match /inquiries/{inquiryId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow list, get: if isAuthenticated() && (resource.data.userId == request.auth.uid || isUserAdmin());
      allow update, delete: if isUserAdmin();
    }
  }
}