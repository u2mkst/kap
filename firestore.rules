
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // 유저 정보
    match /users/{userId} {
      // 개별 조회는 본인 또는 관리자만 가능
      allow get: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // 전체 목록 조회는 관리자만 가능
      allow list: if isAdmin();
      
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // 개인별 행운 점수
      match /personal_fortunes/{date} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // 식물 키우기
      match /plants/{plantId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // 선생님 정보: 모든 사용자가 읽기 가능 (투표 등)
    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 앱 설정 및 공지
    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 관리자 권한 확인
    match /roles_admin/{adminId} {
      // 본인의 권한 여부 확인은 허용
      allow get: if isAuthenticated() && (request.auth.uid == adminId || isAdmin());
      // 전체 관리자 목록은 관리자만 조회 가능
      allow list: if isAdmin();
      
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == adminId);
    }
    
    // 일일 문제
    match /daily_problems/{problemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 오늘의 한마디: 모든 사용자 읽기 허용 (비로그인/로딩 에러 방지)
    match /daily_fortunes/{date} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 문의 시스템 (고객센터)
    match /inquiries/{inquiryId} {
      // 목록 조회(list): 본인의 것만 필터링해서 조회하거나 관리자인 경우 허용
      allow list: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      // 단일 조회(get): 본인의 것이거나 관리자인 경우 허용
      allow get: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // 생성(create): 인증된 사용자가 본인의 userId로 생성할 때 허용
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // 수정/삭제: 본인의 것이거나 관리자인 경우 허용
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
