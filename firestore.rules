
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();

      match /plants/{plantId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /teachers/{teacherId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['vote'])
        && request.resource.data.vote == resource.data.vote + 1;
      allow create, delete: if isAdmin();
    }

    match /metadata/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isAuthenticated();
      // 비밀 코드를 통한 최초 권한 획득을 위해 본인의 문서 생성 허용
      allow create: if isAuthenticated() && request.auth.uid == adminId;
      // 목록 조회 및 타인 권한 관리는 기존 관리자만 가능
      allow list, update, delete: if isAdmin();
    }

    match /daily_fortunes/{date} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /daily_problems/{problemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
