
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUserAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. 공용 데이터 및 문의
    match /inquiries/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isUserAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isUserAdmin());
      allow delete: if isUserAdmin();
    }

    match /roles_admin/{adminId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == adminId;
      allow update, delete: if isUserAdmin();
    }

    // 2. 유저 프로필 및 하위 데이터
    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated(); 
      allow write: if isOwner(userId) || isUserAdmin();
    }

    // 하위 컬렉션들에 대한 명시적 규칙 (권한 오류 방지)
    match /users/{userId}/friends/{friendId} {
      allow read, write: if isOwner(userId) || isUserAdmin();
    }
    match /users/{userId}/invites/{inviteId} {
      allow read, write: if isOwner(userId) || isUserAdmin();
    }
    match /users/{userId}/games/{gameId} {
      allow read, write: if isOwner(userId) || isUserAdmin();
    }
    match /users/{userId}/solved_problems/{problemId} {
      allow read, write: if isOwner(userId) || isUserAdmin();
    }
    match /users/{userId}/personal_fortunes/{fortuneId} {
      allow read, write: if isOwner(userId) || isUserAdmin();
    }
    match /users/{userId}/plants/{plantId} {
      allow read, write: if isOwner(userId) || isUserAdmin();
    }

    // 3. 검 강화 게임 전체 데이터 조회 (순위용)
    match /sword_game_profiles/{profileId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == profileId;
    }

    // 4. 게임 세션
    match /game_sessions/{sessionId} {
      allow read, write: if isAuthenticated() && (request.auth.uid in resource.data.participants || request.auth.uid in request.resource.data.participants);
      
      match /messages/{msgId} {
        allow read, write: if isAuthenticated();
      }
    }

    // 5. 선생님 및 메타데이터
    match /teachers/{teacherId} {
      allow read: if true; 
      allow write: if isUserAdmin();
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
    
    match /daily_problems/{problemId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    match /daily_fortunes/{date} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
  }
}
