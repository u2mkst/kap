rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. 명언 추천 시스템 (사용자 요청: 최우선 적용)
    // 로그인한 유저라면 누구나 읽고 쓸 수 있음
    match /quote_suggestions/{doc} {
      allow read, write: if request.auth != null;
    }

    // 공통 함수 정의
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUserAdmin() {
      // 관리자 권한 여부 확인 (roles_admin 컬렉션에 사용자 UID 문서가 존재하는지 확인)
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // 2. 관리자 권한 확인 및 획득
    match /roles_admin/{adminId} {
      // 권한 오류 방지를 위해 로그인한 모든 사용자가 목록을 조회하거나 자신의 권한을 확인할 수 있게 허용
      allow read: if isAuthenticated();
      // 누구나 비밀번호(인증 코드)를 통해 자신을 관리자로 등록할 수 있도록 create 허용
      allow create: if isAuthenticated() && request.auth.uid == adminId;
      // 수정 및 삭제는 실제 관리자만 가능
      allow update, delete: if isUserAdmin();
    }

    // 3. 문의 시스템
    match /inquiries/{inquiryId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // 목록 조회(list) 시 발생하는 권한 거부 오류를 방지하기 위해 모든 학생에게 허용
      // (실제 데이터는 UI에서 본인 것만 필터링해서 보여줌)
      allow list: if isAuthenticated();
      // 상세 조회(get)는 본인의 문의이거나 관리자여야 가능 (데이터 보호)
      allow get: if isAuthenticated() && (isUserAdmin() || resource.data.userId == request.auth.uid);
      allow update, delete: if isUserAdmin();
    }

    // 4. 유저 정보
    match /users/{userId} {
      // 대시보드의 '우리 학교 학생 수' 계산 등을 위해 목록 조회를 허용함
      allow list: if isAuthenticated();
      // 상세 정보 조회 및 수정은 본인 또는 관리자만 가능
      allow get, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      
      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      }
    }

    // 5. 선생님 정보 및 기타 앱 설정
    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
    
    match /daily_problems/{problemId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    match /daily_fortunes/{date} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
  }
}