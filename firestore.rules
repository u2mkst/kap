
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    match /users/{userId} {
      // 학생들은 자신의 정보를 수정할 수 있고, 다른 학생의 랭킹(포인트)을 볼 수 있어야 함
      allow get: if isAuthenticated();
      allow list: if isAuthenticated(); 
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();

      match /plants/{plantId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /teachers/{teacherId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() 
        && (
          isAdmin() || 
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['vote']) && request.resource.data.vote == resource.data.vote + 1)
        );
      allow create, delete: if isAdmin();
    }

    match /metadata/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isAuthenticated();
      allow create: if isAuthenticated() && (request.auth.uid == adminId || isAdmin());
      allow list, update, delete: if isAdmin();
    }
    
    match /daily_problems/{problemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /daily_fortunes/{date} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
