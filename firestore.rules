rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. 명언 추천 시스템 (사용자 요청: 최우선 적용)
    // 로그인한 유저라면 누구나 읽고 쓸 수 있음
    match /quote_suggestions/{doc} {
      allow read, write: if request.auth != null;
    }

    // 공통 함수 정의
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUserAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // 2. 관리자 권한 확인 및 획득
    // 누구나 비밀번호를 통해 자신을 관리자로 등록할 수 있도록 create 허용
    match /roles_admin/{adminId} {
      allow get, create: if isAuthenticated() && request.auth.uid == adminId;
      allow list, update, delete: if isUserAdmin();
    }

    // 3. 문의 시스템 (학생 조회 권한 수정)
    match /inquiries/{inquiryId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // 관리자이거나, 필터링을 통해 본인의 문의 내역만 보는 경우 허용
      allow list: if isAuthenticated() && (isUserAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isAuthenticated() && (isUserAdmin() || resource.data.userId == request.auth.uid);
      allow update, delete: if isUserAdmin();
    }

    // 4. 유저 정보 및 하위 컬렉션
    match /users/{userId} {
      allow get, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      allow list: if isUserAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      }
    }

    // 5. 선생님 정보 및 기타 앱 설정
    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
    
    match /daily_problems/{problemId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    match /daily_fortunes/{date} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
  }
}