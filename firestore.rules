
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // 유저 정보: 인증된 사용자는 목록과 개별 조회가 가능함
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // 개인별 행운 점수
      match /personal_fortunes/{date} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      // 식물 키우기
      match /plants/{plantId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // 선생님/메타데이터: 누구나 읽을 수 있게 하여 초기 로딩 에러 방지
    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 관리자 권한: 본인 확인 및 관리자 제어
    match /roles_admin/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == adminId);
    }
    
    // 일일 문제/운세
    match /daily_problems/{problemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /daily_fortunes/{date} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 문의 시스템
    match /inquiries/{inquiryId} {
      // 본인 문의만 읽기 가능, 관리자는 전체 읽기 가능
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
