
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // 유저 정보
    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      match /personal_fortunes/{date} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /plants/{plantId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // 선생님 정보
    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 앱 설정 및 공지
    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 관리자 권한 확인
    match /roles_admin/{adminId} {
      allow get: if isAuthenticated() && (request.auth.uid == adminId || isAdmin());
      allow list: if isAdmin();
      allow write: if isAdmin();
    }
    
    // 일일 문제
    match /daily_problems/{problemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 오늘의 한마디
    match /daily_fortunes/{date} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 문의 시스템 (고객센터)
    match /inquiries/{inquiryId} {
      // 목록 조회(list): 쿼리 필터가 userId와 일치해야 함
      allow list: if isAuthenticated() && (
        isAdmin() || 
        (resource == null || resource.data.userId == request.auth.uid)
      );
      // 단일 조회(get): 본인의 것이거나 관리자인 경우 허용
      allow get: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.userId == request.auth.uid)
      );
      // 생성(create): 인증된 사용자가 본인의 userId로 생성할 때 허용
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // 수정/삭제: 본인의 것이거나 관리자인 경우 허용
      allow update, delete: if isAuthenticated() && (
        isAdmin() || 
        (resource.data.userId == request.auth.uid)
      );
    }
  }
}
