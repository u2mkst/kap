
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();

      match /plants/{plantId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /teachers/{teacherId} {
      allow read: if isAuthenticated();
      // 투표는 로그인한 사용자만 가능하며, vote 필드만 증가시킬 수 있음
      allow update: if isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['vote']);
      allow create, delete: if isAdmin();
    }

    match /metadata/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
    }
  }
}
