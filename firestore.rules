
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUserAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // 1. 공용 데이터 (로그인 유저라면 목록 조회 포함 전체 허용 - 사용자 요청 최우선)
    match /quote_suggestions/{doc} {
      allow read, write: if isAuthenticated();
    }

    match /inquiries/{doc} {
      allow read, write: if isAuthenticated();
    }

    // 2. 관리자 권한 확인 및 획득 (권한 확인 과정의 팝업 오류 방지를 위해 목록 조회 개방)
    match /roles_admin/{adminId} {
      allow read: if isAuthenticated();
      // 누구나 자신의 관리자 문서를 생성할 수 있음 (앱의 Secret Code 로직과 결합됨)
      allow create: if isAuthenticated() && request.auth.uid == adminId;
      allow update, delete: if isUserAdmin();
    }

    // 3. 유저 프로필 및 하위 데이터
    match /users/{userId} {
      // 대시보드 통계를 위해 목록 조회 허용
      allow list: if isAuthenticated();
      allow get: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      
      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      }
    }

    // 4. 선생님 및 메타데이터 (관리자 전용 쓰기)
    match /teachers/{teacherId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
    
    match /daily_problems/{problemId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    match /daily_fortunes/{date} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
  }
}
