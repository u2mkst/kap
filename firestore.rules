
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. 공용 데이터 (로그인 유저라면 목록 조회 포함 전체 허용)
    match /quote_suggestions/{doc} {
      allow read, write: if request.auth != null;
    }

    match /inquiries/{doc} {
      allow read, write: if request.auth != null;
    }

    // 2. 관리자 권한 확인 (권한 확인 과정의 팝업 오류 방지를 위해 목록 조회 개방)
    match /roles_admin/{adminId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == adminId;
      allow update, delete: if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // 3. 유저 프로필 및 하위 데이터
    match /users/{userId} {
      // 대시보드 통계를 위해 목록 조회 허용
      allow list: if request.auth != null;
      allow get: if request.auth != null && (request.auth.uid == userId || exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
      allow write: if request.auth != null && (request.auth.uid == userId || exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
      
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
      }
    }

    // 4. 선생님 및 메타데이터
    match /teachers/{teacherId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    match /daily_problems/{problemId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    match /daily_fortunes/{date} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
  }
}
