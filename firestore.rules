
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)); }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      // 일반 사용자는 조회가 가능하지만, 전체 목록 조회(list) 시에는 특정 필터가 필요할 수 있음
      // 여기서는 관리자이거나 로그인한 사용자면 조회를 허용하되, Admin 페이지의 무차별 list는 위단에서 막음
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.authorId || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']));
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    match /daily_fortunes/{fortuneDate} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /daily_problems/{problemDate} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_admin/{adminId} { allow get: if isSignedIn(); allow write: if false; }
  }
}
