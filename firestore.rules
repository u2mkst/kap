rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // [공통 함수]
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUserAdmin() {
      // roles_admin 컬렉션에 사용자 UID 문서가 존재하는지 확인
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // 1. 명언 추천 시스템 (사용자 요청: 최상단 배치 및 전원 개방)
    match /quote_suggestions/{doc} {
      allow read, write: if isAuthenticated();
    }

    // 2. 관리자 권한 확인 및 획득
    match /roles_admin/{adminId} {
      // 권한 확인을 위해 목록 및 개별 문서 조회를 모든 학생에게 허용
      allow read: if isAuthenticated();
      // 누구나 인증 코드를 통해 자신을 관리자로 등록(Claim)할 수 있도록 허용
      allow create: if isAuthenticated() && request.auth.uid == adminId;
      // 실제 관리자만 수정 및 삭제 가능
      allow update, delete: if isUserAdmin();
    }

    // 3. 문의 시스템 (고객센터)
    match /inquiries/{inquiryId} {
      // 본인의 UID로만 문의 생성 가능
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // 목록 조회 권한 거부 오류 방지를 위해 모든 학생에게 허용 (UI에서 본인 것만 필터링)
      allow list: if isAuthenticated();
      // 상세 조회는 본인 또는 관리자만 가능 (데이터 보호)
      allow get: if isAuthenticated() && (isUserAdmin() || resource.data.userId == request.auth.uid);
      // 답변 작성 및 삭제는 관리자만
      allow update, delete: if isUserAdmin();
    }

    // 4. 유저 프로필 및 정보
    match /users/{userId} {
      // 통계 및 랭킹을 위해 목록 조회를 허용함
      allow list: if isAuthenticated();
      // 프로필 상세 조회는 로그인 유저라면 가능
      allow get: if isAuthenticated();
      // 수정은 본인 또는 관리자만
      allow write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      
      // 하위 컬렉션(출석, 식물, 행운 등)은 본인 또는 관리자만
      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      }
    }

    // 5. 선생님 및 앱 설정 데이터
    match /teachers/{teacherId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
    
    match /daily_problems/{problemId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    match /daily_fortunes/{date} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
  }
}