rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // [공통 함수]
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUserAdmin() {
      // roles_admin 컬렉션에 사용자 UID 문서가 존재하는지 확인
      return isAuthenticated() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // 1. 고객센터 및 명언 추천 (사용자 요청: 최우선 전면 개방)
    // 로그인한 사용자라면 누구나 읽고 쓸 수 있도록 설정
    match /quote_suggestions/{doc} {
      allow read, write: if isAuthenticated();
    }

    match /inquiries/{doc} {
      allow read, write: if isAuthenticated();
    }

    // 2. 관리자 권한 확인 및 획득
    match /roles_admin/{adminId} {
      // 권한 확인을 위해 목록 조회를 모든 학생에게 허용
      allow read: if isAuthenticated();
      // 누구나 인증 코드를 통해 자신을 관리자로 등록(Claim)할 수 있도록 허용
      allow create: if isAuthenticated() && request.auth.uid == adminId;
      // 실제 관리자만 수정 및 삭제 가능
      allow update, delete: if isUserAdmin();
    }

    // 3. 유저 프로필 및 정보
    match /users/{userId} {
      // 통계 및 랭킹, 학교 인원 표시를 위해 목록 조회를 허용
      allow list: if isAuthenticated();
      // 프로필 상세 조회는 로그인 유저라면 가능
      allow get: if isAuthenticated();
      // 수정은 본인 또는 관리자만
      allow write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      
      // 하위 컬렉션(출석, 식물, 행운 등)은 본인 또는 관리자만
      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isUserAdmin());
      }
    }

    // 4. 선생님 및 앱 설정 데이터
    match /teachers/{teacherId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
    
    match /daily_problems/{problemId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    match /daily_fortunes/{date} {
      allow read: if true;
      allow write: if isUserAdmin();
    }
  }
}